# RunMyCrew API — local dev env template.
#
# Copy to apps/api/.env and fill in the secrets you actually need. Every
# key below has a sensible default in app/core/config.py except the
# OAuth / LLM-provider secrets, which are empty out of the box — the
# matching feature stays disabled until you set them.

# ── Core ──────────────────────────────────────────────────────────────
# Defaults are fine for local. Change for prod.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3001
ENVIRONMENT=development

# ── Postgres ──────────────────────────────────────────────────────────
# Defaults match docker-compose db service. Override for native Postgres.
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=runmycrew

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── LLM providers (fill in to use the AI agent) ───────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ── OAuth providers (fill in to enable the matching sign-in / integration) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=
GOOGLE_APP_ID=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Meta / Facebook / Instagram — only needed for the Meta integration nodes.
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_FB_LOGIN_CONFIG_ID=
META_INSTAGRAM_APP_ID=
META_INSTAGRAM_APP_SECRET=

# ── Email (SMTP — used by escalation handler) ─────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@runmycrew.com
SMTP_FROM_NAME=RunMyCrew
SMTP_TLS=true

# ── Observability ─────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# ── Code sandbox (optional — for code-execution nodes) ────────────────
CODE_SANDBOX=auto
CODE_SANDBOX_PYTHON_IMAGE=python:3.13-slim
CODE_SANDBOX_NODE_IMAGE=node:22-alpine
CODE_SANDBOX_MEMORY_MB=512

# ── Public reachable URL (only needed when third parties pull from us) ──
# Set to your Cloudflare tunnel / ngrok hostname when Meta needs to fetch
# uploaded assets. Leave blank for local-only flows.
PUBLIC_BASE_URL=
