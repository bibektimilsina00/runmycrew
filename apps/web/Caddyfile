{
	# Email for Let's Encrypt expiry / revocation notices. Swap if you
	# want them going elsewhere.
	email support@khareedlow.com

	# Default Caddy auto-issues from Let's Encrypt and renews 30 days
	# before expiry. No certbot required.
}

# ── Production domain ──────────────────────────────────────────────────
fuse.bibektimilsina.tech {
	# Compress everything Caddy serves and proxies.
	encode zstd gzip

	# ── Healthcheck ─────────────────────────────────────────────────
	# Container-local healthcheck — does NOT touch the API, so the web
	# container reports healthy independently of upstream state.
	@healthz path /healthz
	respond @healthz "ok" 200

	# ── Backend routes ──────────────────────────────────────────────
	# Anything the API owns: /api/*, websockets at /ws/*, plus the
	# OpenAPI docs paths so dev tools work in production too.
	@api {
		path /api/* /ws/* /openapi.json /docs /docs/* /redoc /redoc/*
	}
	handle @api {
		reverse_proxy api:8000 {
			# Caddy auto-passes X-Forwarded-{For,Proto,Host} — only set
			# headers it doesn't fill itself.
			header_up X-Real-IP {remote_host}
			# Long timeout for SSE / streaming workflow logs.
			transport http {
				read_buffer 64KB
				write_buffer 64KB
				dial_timeout 10s
				response_header_timeout 60s
			}
		}
	}

	# ── Static frontend ─────────────────────────────────────────────
	root * /srv

	# Vite emits content-hashed filenames under /assets/* — safe to
	# cache forever; the hash changes on rebuild.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# index.html must never get cached so users see the latest build
	# the moment we ship.
	@index path / /index.html
	header @index Cache-Control "no-cache, no-store, must-revalidate"

	# ── Security headers ────────────────────────────────────────────
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}

	# SPA fallback — every other path serves index.html so React
	# Router owns the URL space.
	file_server
	try_files {path} /index.html
}

# ── HTTP fallback (also redirected to HTTPS by Caddy by default) ───────
# Caddy automatically issues a 308 redirect from :80 to :443 for the
# managed site above, so no explicit `http://` block is needed.
