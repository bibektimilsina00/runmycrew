# ─── Fuse production env ────────────────────────────────────────────────
# Copy to `deploy/.env` on the VPS and fill every required value.
# This file is committed; the real `.env` is git-ignored.
#
#   cp deploy/.env.production.example deploy/.env
#   chmod 600 deploy/.env
#
# Rotate any secret by editing the value and running `./deploy.sh`.
# ────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────
PROJECT_NAME=Fuse
API_V1_STR=/api/v1
BASE_URL=https://fuse.bibektimilsina.tech
FRONTEND_URL=https://fuse.bibektimilsina.tech

# ── Image registry / tag ───────────────────────────────────────────────
# Owner of the ghcr repository (`ghcr.io/<owner>/fuse-{api,worker,web}`).
GITHUB_OWNER=bibektimilsina00
# `latest` tracks main. Pin to `sha-<short>` to lock a release or roll back.
FUSE_IMAGE_TAG=latest

# ── Security — REQUIRED ────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ── Postgres ──────────────────────────────────────────────────────────
# Use a strong password. Generated value must be quoted-safe (no `$`).
POSTGRES_USER=fuse
POSTGRES_PASSWORD=
POSTGRES_DB=fuse
POSTGRES_SERVER=db

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── SMTP (optional) ───────────────────────────────────────────────────
# Without these, workspace invites and password-reset emails are
# logged to stdout instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Fuse
SMTP_TLS=true

# ── OAuth providers (fill what you actually use) ──────────────────────
# Each provider's callback URL on production becomes:
#   https://fuse.bibektimilsina.tech/api/v1/credentials/oauth/<service>/callback
# Update the redirect URI in every provider console after first deploy.

# Google (Gmail + Calendar + Drive + Sheets + Docs + Tasks + Forms +
# Contacts + YouTube + Slides + Chat + Analytics 4 + Cloud Storage +
# Search Console — all share one OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Flip on to upgrade `drive.file` → `drive` for folder-watch on
# externally-uploaded files. Requires Google CASA / restricted-scope
# verification first.
GOOGLE_DRIVE_WATCH_EXTERNAL=false

# Meta (Instagram + Facebook + WhatsApp + Lead Ads)
META_APP_ID=
META_APP_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Notion (public integration only)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Linear
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ── AI provider API keys (fill what you use) ──────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=

# ── Sentry (optional, Phase 1 hardening) ──────────────────────────────
SENTRY_DSN=

# ── Misc ──────────────────────────────────────────────────────────────
# Override if you change ports / want logs in a different TZ.
TZ=UTC
