# ─── RunMyCrew production env ───────────────────────────────────────────
# Copy to `deploy/.env` on the VPS and fill every required value.
# This file is committed; the real `.env` is git-ignored.
#
#   cp deploy/.env.production.example deploy/.env
#   chmod 600 deploy/.env
#
# Rotate any secret by editing the value and running `./deploy.sh`.
# ────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────
PROJECT_NAME=RunMyCrew
API_V1_STR=/api/v1
BASE_URL=https://app.runmycrew.com
FRONTEND_URL=https://app.runmycrew.com

# ── Image registry / tag ───────────────────────────────────────────────
# Owner of the ghcr repository (`ghcr.io/<owner>/runmycrew-{api,worker,web,site}`).
GITHUB_OWNER=bibektimilsina00
# `latest` tracks main. Pin to `sha-<short>` to lock a release or roll back.
RUNMYCREW_IMAGE_TAG=latest

# ── Security — REQUIRED ────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ── Postgres ──────────────────────────────────────────────────────────
# Use a strong password. Generated value must be quoted-safe (no `$`).
POSTGRES_USER=runmycrew
POSTGRES_PASSWORD=
POSTGRES_DB=runmycrew
POSTGRES_SERVER=db

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Email (optional) ──────────────────────────────────────────────────
# Without one of these, workspace invites and password-reset emails are
# logged to stdout instead of sent. SMTP_FROM / SMTP_FROM_NAME are also
# used by the Resend provider as the From address — set them either way.
#
# Resend HTTP API (PREFERRED — port 443 only, immune to provider SMTP
# port blocks like DigitalOcean's 25/465/587 block).
RESEND_API_KEY=
SMTP_FROM=
SMTP_FROM_NAME=RunMyCrew
#
# SMTP fallback (Gmail / SES relay / Mailgun / …). On hosts that block
# outbound SMTP, set SMTP_PORT to a provider-supplied alternate (Resend
# offers 2587 over 587).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# ── RapidAPI (YouTube transcript op) ──────────────────────────────────
# Needed by the YouTube node's "Get Video Transcript" operation.
# YouTube blocks direct timedtext scraping from cloud IPs (DigitalOcean,
# AWS, GCP), so we proxy through RapidAPI. Sign up at rapidapi.com,
# subscribe to a YouTube-transcript provider (e.g. "youtube-transcriptor",
# 500 req/mo free), copy the X-RapidAPI-Key into RAPIDAPI_KEY and the
# provider host into RAPIDAPI_YOUTUBE_TRANSCRIPT_HOST. If unset, the
# node falls back to direct scrape which works locally but typically
# fails in production.
RAPIDAPI_KEY=
RAPIDAPI_YOUTUBE_TRANSCRIPT_HOST=youtube-transcriptor.p.rapidapi.com

# ── OAuth providers (fill what you actually use) ──────────────────────
# Each provider's callback URL on production becomes:
#   https://app.runmycrew.com/api/v1/credentials/oauth/<service>/callback
# Update the redirect URI in every provider console after first deploy.

# Google (Gmail + Calendar + Drive + Sheets + Docs + Tasks + Forms +
# Contacts + YouTube + Slides + Chat + Analytics 4 + Cloud Storage +
# Search Console — all share one OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Browser-side API key for the Google Picker (Drive folder selector
# in the workflow editor). Restrict to the `app.runmycrew.com/*`
# referrer + the `Google Picker API` in Cloud Console → Credentials.
GOOGLE_API_KEY=
# GCP project number (NOT project ID) for the Picker. Find it in
# Cloud Console → top bar → project picker → Project info → "Project
# number" (a long integer).
GOOGLE_APP_ID=
# Flip on to upgrade `drive.file` → `drive` for folder-watch on
# externally-uploaded files. Requires Google CASA / restricted-scope
# verification first.
GOOGLE_DRIVE_WATCH_EXTERNAL=false

# Meta (Instagram + Facebook + WhatsApp + Lead Ads)
META_APP_ID=
META_APP_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# GitHub — used for both sign-in AND the GitHub action/trigger nodes.
# Same OAuth app, two callback URIs registered.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft (Azure AD / Entra ID) — sign-in only.
# `MICROSOFT_TENANT=common` accepts both personal Microsoft accounts
# and work/school Entra accounts. Lock to a specific tenant id for
# SSO-only deployments.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Notion (public integration only)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Linear
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ── AI provider API keys (fill what you use) ──────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=

# ── Sentry (optional, Phase 1 hardening) ──────────────────────────────
SENTRY_DSN=

# ── Misc ──────────────────────────────────────────────────────────────
# Override if you change ports / want logs in a different TZ.
TZ=UTC
